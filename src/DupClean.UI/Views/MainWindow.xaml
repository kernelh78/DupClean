<Window x:Class="DupClean.UI.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:DupClean.UI.ViewModels"
        Title="DupClean — 중복 파일 정리"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500"
        Background="{StaticResource SurfaceBrush}"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.InputBindings>
        <KeyBinding Key="F5"   Command="{Binding ScanCommand}"/>
        <KeyBinding Key="Z"    Modifiers="Ctrl" Command="{Binding UndoCommand}"/>
        <KeyBinding Key="Escape" Command="{Binding CancelScanCommand}"/>
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- 툴바 -->
            <RowDefinition Height="Auto"/>   <!-- 진행 바 -->
            <RowDefinition Height="*"/>      <!-- 본문 -->
            <RowDefinition Height="Auto"/>   <!-- 상태바 -->
        </Grid.RowDefinitions>

        <!-- ── 툴바 ────────────────────────────────────────── -->
        <Border Grid.Row="0" Padding="16,12"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 폴더 경로 -->
                <Grid Grid.Column="0" Margin="0,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding FolderPath, UpdateSourceTrigger=PropertyChanged}"
                             Padding="10,8"
                             FontSize="13"
                             VerticalContentAlignment="Center"
                             BorderBrush="{StaticResource BorderBrush}"
                             BorderThickness="1,1,0,1"/>
                    <Button Grid.Column="1"
                            Content="폴더 선택"
                            Style="{StaticResource GhostButton}"
                            Command="{Binding BrowseFolderCommand}"
                            BorderThickness="1"
                            Margin="0"/>
                </Grid>

                <!-- 스캔 -->
                <Button Grid.Column="1" Margin="4,0"
                        Content="▶  스캔 (F5)"
                        Style="{StaticResource PrimaryButton}"
                        Command="{Binding ScanCommand}"
                        IsEnabled="{Binding IsBusy, Converter={x:Static BooleanToVisibilityConverter}, ConverterParameter=Inverse}"/>

                <!-- 취소 -->
                <Button Grid.Column="2" Margin="4,0"
                        Content="■  취소"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding CancelScanCommand}"
                        Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"/>

                <!-- 격리 이동 -->
                <Button Grid.Column="3" Margin="4,0"
                        Content="📦  격리 이동"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding QuarantineCommand}"/>

                <!-- 휴지통 -->
                <Button Grid.Column="4" Margin="4,0"
                        Content="🗑  삭제"
                        Style="{StaticResource DangerButton}"
                        Command="{Binding DeleteCommand}"/>

                <!-- Undo -->
                <Button Grid.Column="5" Margin="4,0"
                        Content="↩  Undo (Ctrl+Z)"
                        Style="{StaticResource GhostButton}"
                        Command="{Binding UndoCommand}"/>
            </Grid>
        </Border>

        <!-- ── 진행 바 ─────────────────────────────────────── -->
        <Border Grid.Row="1"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                Padding="16,8"
                Background="#EFF6FF">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>
                <ProgressBar Grid.Row="0"
                             Value="{Binding ProgressPercent}"
                             Maximum="100" Height="6"
                             Foreground="{StaticResource PrimaryBrush}"
                             BorderThickness="0"/>
                <TextBlock Grid.Row="1" Margin="0,4,0,0"
                           Text="{Binding ProgressText}"
                           FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"/>
            </Grid>
        </Border>

        <!-- ── 본문 ────────────────────────────────────────── -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340" MinWidth="240"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 왼쪽: 중복 그룹 목록 -->
            <Border Grid.Column="0"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="16,10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="중복 그룹" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Margin="8,0,0,0"
                                       Text="{Binding Groups.Count, StringFormat=({0}개)}"
                                       Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <ListBox Grid.Row="1"
                             ItemsSource="{Binding Groups}"
                             SelectedItem="{Binding SelectedGroup}"
                             BorderThickness="0"
                             Background="Transparent">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding GroupLabel}"
                                           TextWrapping="Wrap"
                                           Padding="12,8"
                                           FontSize="12"/>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- 요약 -->
                    <Border Grid.Row="2" Padding="16,10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Visibility="{Binding ScanSummary, Converter={StaticResource NullToCollapsed}}">
                        <StackPanel>
                            <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                                <Run Text="스캔 파일: "/>
                                <Run Text="{Binding ScanSummary.ScannedFiles, StringFormat={}{0:N0}개}"/>
                            </TextBlock>
                            <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}">
                                <Run Text="절약 가능: "/>
                                <Run Text="{Binding ScanSummary.ReclaimableBytes, Converter={StaticResource BytesConverter}}"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 구분선 드래그 -->
            <GridSplitter Grid.Column="1" Width="5"
                          HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- 오른쪽: 선택된 그룹 파일 목록 -->
            <Border Grid.Column="2">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Padding="16,10"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="파일 목록" FontWeight="SemiBold" FontSize="13"/>
                            <TextBlock Margin="8,0,0,0" FontSize="11"
                                       Foreground="{StaticResource TextMutedBrush}">
                                파일을 선택 후 격리 이동 또는 삭제
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <ListView Grid.Row="1"
                              ItemsSource="{Binding SelectedGroup.Files}"
                              BorderThickness="0"
                              SelectionMode="Extended">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="30">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected}"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="파일명" Width="260"
                                               DisplayMemberBinding="{Binding FileName}"/>
                                <GridViewColumn Header="크기"   Width="90"
                                               DisplayMemberBinding="{Binding SizeText}"/>
                                <GridViewColumn Header="수정일" Width="140"
                                               DisplayMemberBinding="{Binding Modified}"/>
                                <GridViewColumn Header="경로"   Width="400"
                                               DisplayMemberBinding="{Binding FullPath}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- ── 상태바 ─────────────────────────────────────── -->
        <Border Grid.Row="3" Padding="16,8"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                Background="White">
            <TextBlock Text="{Binding StatusMessage}"
                       FontSize="12"
                       Foreground="{StaticResource TextMutedBrush}"/>
        </Border>
    </Grid>
</Window>
